<%#
  A single field row. The edit form is rendered inline and toggled.
%>
<div class="px-4 py-2.5 flex items-center gap-3" data-controller="toggle" id="field-<%= field.id %>">
  <div class="flex-1 min-w-0">
    <div class="text-sm font-medium text-slate-800 truncate">
      <%= field.label %>
      <% if field.behavior != "mine" %>
        <span class="ml-1 text-xs text-slate-400 font-normal">
          <%= Field::BEHAVIOR_LABELS[field.behavior] %>
        </span>
      <% end %>
    </div>
  </div>

  <%= form_with url: month_field_path(@month, field), method: :patch, local: true,
                class: "flex items-center gap-2" do |f| %>
    <div class="relative">
      <span class="absolute left-2 top-1/2 -translate-y-1/2 text-slate-400 text-sm">£</span>
      <%= f.number_field "field[value]", value: field.value.to_s.sub(/\.00\z/, ""),
            step: "0.01", min: 0, inputmode: "decimal", placeholder: "0",
            class: "w-28 pl-6 pr-2 py-1.5 rounded-md border border-slate-300 text-sm text-right tabular-nums focus:outline-none focus:ring-2 focus:ring-slate-500" %>
    </div>
    <%= f.submit "Save", class: "sr-only" %>
  <% end %>

  <% if field.behavior == "shared" %>
    <span class="text-xs text-slate-500 tabular-nums w-20 text-right">
      <%= field.value.to_f.zero? ? "" : gbp(field.share_amount) %>
    </span>
  <% else %>
    <span class="w-20"></span>
  <% end %>

  <button type="button" data-action="toggle#toggle"
          data-toggle-target-param="edit-<%= field.id %>"
          class="text-slate-400 hover:text-slate-700 text-sm cursor-pointer w-6 text-center" title="Edit">✎</button>

  <%= button_to month_field_path(@month, field), method: :delete,
        form_class: "inline",
        data: { turbo_confirm: "Remove \"#{field.label}\"?" },
        class: "text-slate-400 hover:text-rose-600 text-lg cursor-pointer w-6 leading-none" do %>&times;<% end %>
</div>

<div id="edit-<%= field.id %>" class="hidden px-4 py-3 bg-slate-50 border-t border-slate-100">
  <%= form_with url: month_field_path(@month, field), method: :patch, local: true,
                class: "flex flex-wrap items-center gap-2" do |f| %>
    <%= f.text_field "field[label]", value: field.label, required: true,
          class: "flex-1 min-w-[10rem] rounded-md border border-slate-300 px-2.5 py-1.5 text-sm" %>
    <%= f.select "field[behavior]",
          Field::BEHAVIORS.map { |b| [ Field::BEHAVIOR_LABELS[b], b ] },
          { selected: field.behavior },
          class: "rounded-md border border-slate-300 px-2 py-1.5 text-sm" %>
    <label class="text-xs text-slate-600 flex items-center gap-1">
      <%= f.check_box "field[reset_on_new]", { checked: field.reset_on_new? }, "true", "false" %>
      Reset monthly
    </label>
    <%= f.submit "Save",
          class: "px-3 py-1.5 rounded-md bg-slate-900 text-white text-sm font-medium hover:bg-slate-800 cursor-pointer" %>
  <% end %>
</div>
