<%# locals: months:, month: (the currently selected month, or nil) %>
<div data-drawer-target="backdrop"
     data-action="click->drawer#close"
     class="fixed inset-0 z-30 bg-black/40 hidden md:hidden"></div>

<aside data-drawer-target="panel"
       class="fixed top-0 left-0 z-40 h-screen w-64 bg-slate-900 text-slate-200 flex flex-col
              transition-transform duration-200 -translate-x-full
              md:relative md:w-56 md:translate-x-0">
  <div class="flex items-center justify-between px-4 pt-5 pb-3">
    <h1 class="text-xl font-bold text-white tracking-tight">Budget</h1>
    <div class="flex items-center gap-1">
      <%= button_to months_path, method: :post,
            form_class: "inline",
            class: "min-w-10 min-h-10 md:w-8 md:h-8 md:min-w-0 md:min-h-0 rounded-md bg-slate-700 hover:bg-slate-600 text-white text-lg leading-none flex items-center justify-center cursor-pointer",
            title: "Add next month" do %>+<% end %>
      <button type="button" data-action="drawer#close"
              class="md:hidden min-w-10 min-h-10 rounded-md text-slate-300 hover:bg-slate-800 text-2xl leading-none flex items-center justify-center cursor-pointer"
              aria-label="Close menu">&times;</button>
    </div>
  </div>

  <ul id="sidebar-months" class="flex-1 overflow-y-auto px-2 pb-4 space-y-0.5">
    <% months.each do |m| %>
      <%= render "months/sidebar_item", m: m, active: m == month %>
    <% end %>
  </ul>

  <div class="px-4 py-3 border-t border-slate-800">
    <%= button_to "Log out", logout_path, method: :delete,
          class: "w-full text-left text-xs text-slate-400 hover:text-slate-200 cursor-pointer" %>
  </div>
</aside>
