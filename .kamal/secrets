# Secrets sourced for `bin/kamal`. This file is committed; the actual values
# come from your local environment so nothing sensitive lands in git.

# GitHub personal access token (classic, with `read:packages` and
# `write:packages`). Used to push and pull from ghcr.io.
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

# Rails master key — required to decrypt config/credentials.yml.enc on boot.
RAILS_MASTER_KEY=$(cat config/master.key)

# Bcrypt hash of the shared login password. Generate locally with:
#   bin/rails runner 'puts BCrypt::Password.create("your-password")'
# then `export BUDGET_PASSWORD_HASH='<paste>'` before running any kamal command.
BUDGET_PASSWORD_HASH=$BUDGET_PASSWORD_HASH
