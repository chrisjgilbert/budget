# Kamal reads this file (via `kamal envify` or your shell) and forwards
# referenced values to the containers. It must NOT be committed with real
# values — the committed version only shows which env vars to provide.
#
# Local workflow:
#   1. Copy this file to .kamal/secrets.local (gitignored).
#   2. Fill in real values.
#   3. Source it before running kamal: `set -a; source .kamal/secrets.local; set +a`.
# CI workflow: inject these as masked environment variables.

KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD
RAILS_MASTER_KEY=$(cat config/master.key 2>/dev/null || echo)
POSTGRES_PASSWORD=$POSTGRES_PASSWORD
# APP_PASSWORD_HASH lives inside Rails encrypted
# credentials (config/credentials.yml.enc) — set via `bin/rails credentials:edit`.
